{
  "name": "@openorca-ui/react",
  "version": "0.0.1",
  "description": "Reusable React components and hooks for OpenOrca UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahimailabs/openorca-ui.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts"
  },
  "dependencies": {
    "@openorca-ui/core": "0.0.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./contexts/*": {
      "types": "./dist/contexts/*.d.ts",
      "import": "./dist/contexts/*.js"
    },
    "./assets/*": "./dist/assets/*"
  }
}
